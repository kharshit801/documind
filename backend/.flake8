[flake8]
max-line-length = 100
extend-ignore =
    # whitespace before ':' — disagrees with black
    E203,
    # line break before binary operator — disagrees with black
    W503,
exclude =
    .git,
    __pycache__,
    .venv,
    build,
    dist,
    .pytest_cache,
per-file-ignores =
    __init__.py: F401
