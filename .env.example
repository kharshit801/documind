# =============================================================================
# DocuMind — example environment configuration
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# =============================================================================

# ---- LLM & Embeddings -------------------------------------------------------
OPENAI_API_KEY=sk-replace-me
EMBEDDING_MODEL=text-embedding-3-small
LLM_MODEL=gpt-4o-mini

# ---- Pinecone ---------------------------------------------------------------
PINECONE_API_KEY=replace-me
PINECONE_INDEX_NAME=documind
PINECONE_ENVIRONMENT=us-east-1-aws

# ---- App --------------------------------------------------------------------
APP_ENV=development                  # development | production
MAX_FILE_SIZE_MB=20
CHUNK_SIZE=500
CHUNK_OVERLAP=50
TOP_K_RESULTS=5

# Comma-separated origins, or "*" for any (good for local dev only).
CORS_ALLOW_ORIGINS=*

# ---- AWS (used by Terraform / GitHub Actions, not the runtime app) ---------
AWS_REGION=us-east-1
S3_BUCKET_NAME=documind-uploads
